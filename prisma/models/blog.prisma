model BlogPost {
    id          String    @id @default(uuid())
    title       String
    slug        String    @unique
    content     String    @db.Text
    excerpt     String?
    coverImage  String?
    tags        String[]
    published   Boolean   @default(false)
    publishedAt DateTime?
    createdAt   DateTime  @default(now())
    updatedAt   DateTime  @updatedAt

    @@map("blog_posts")
}
